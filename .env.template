# ============================================================
# ThinkLingo — API Configuration Template
# Copy this file to .env and fill in the API keys you need.
# At least ONE provider key is required to start the server.
# ============================================================

# ── DeepSeek (default main LLM) ──────────────────────────────
# Get key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── OpenAI (default translation LLM) ─────────────────────────
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── Anthropic / Claude ────────────────────────────────────────
# Option A — Regular API key (sk-ant-api03-...), get at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Option B — OAuth token from Claude Code CLI (sk-ant-oat01-...), valid 8 hours
#   Obtain: run `claude setup-token` in terminal, paste the output here
#   Doc: uses Authorization: Bearer header + anthropic-beta: oauth-2025-04-20
# ANTHROPIC_AUTH_TOKEN=sk-ant-oat01-your_token_here

# ── Google / Gemini ───────────────────────────────────────────
# Get key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── Alibaba Cloud / Qwen (DashScope) ─────────────────────────
# Get key at: https://dashscope.console.aliyun.com/apiKey
QWEN_API_KEY=your_qwen_api_key_here
# Optional: override regional endpoint (default = international)
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  # China

# ============================================================
# LLM Provider Selection
# Supported values: deepseek | openai | gpt35 | claude | gemini | qwen
# ============================================================
DEFAULT_LLM_PROVIDER=deepseek
TRANSLATION_LLM_PROVIDER=gpt35

# ============================================================
# Model Configuration
# ============================================================
# DeepSeek: deepseek-chat (V3.2) | deepseek-reasoner (R1)
DEEPSEEK_MODEL=deepseek-chat

# OpenAI: gpt-4o | gpt-4o-mini | o3-mini | o1
OPENAI_MODEL=gpt-4o-mini
GPT35_MODEL=gpt-3.5-turbo

# Anthropic: claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-opus-4-6

# Google: gemini-3.1-pro-preview | gemini-2.5-flash | gemini-2.5-pro
GEMINI_MODEL=gemini-3.1-pro-preview

# Alibaba: qwen3.5-plus | qwen3-max | qwen-plus | qwq-plus | qwen-turbo
QWEN_MODEL=qwen3.5-plus

# ============================================================
# Runtime Configuration
# ============================================================
DEFAULT_RESPONSE_TYPE=general
DEFAULT_TEMPERATURE=0.7
MAX_TOKENS=4000

# CORS origins — comma-separated; add your domain in production
CORS_ORIGINS=http://localhost:3000

MAX_WORKERS=40
MAX_HISTORY_TURNS=20

# WebSocket concurrency limits
MAX_WS_CONNECTIONS=200
MAX_WS_CONNECTIONS_PER_IP=5
WS_RATE_LIMIT_PER_SEC=5

# Set to true to allow users to supply their own API keys via the frontend
ALLOW_USER_API_KEYS=true

# Optional: shared secret to protect all endpoints (REST + WebSocket).
# When set, clients must send Authorization: Bearer <token> (REST) or
# ?token=<token> query param (WebSocket). Leave empty to disable auth.
# Dynamic session tokens (POST /api/session) are also accepted when AUTH_TOKEN is set.
# AUTH_TOKEN=your_secret_token_here

# Dynamic session token settings
SESSION_TTL_SECONDS=3600
# Max session creations per IP per hour (0 = unlimited, default)
# Public deployment: set to a specific number, e.g. 10
MAX_SESSIONS_PER_IP_PER_HOUR=0

# Per-IP daily message quota (0 = unlimited, default)
# Self-deployed users: leave as 0 (no limits)
# Public deployment: set to a specific number, e.g. 200
DAILY_MESSAGE_QUOTA_PER_IP=0
