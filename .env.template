# API Configuration Template
# Copy this file to .env and fill in your API keys

# DeepSeek API Key (Default provider for main processing)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI API Key (For translation tasks - GPT-3.5 is faster and cheaper)
OPENAI_API_KEY=your_openai_api_key_here

# LLM Configuration
DEFAULT_LLM_PROVIDER=deepseek
TRANSLATION_LLM_PROVIDER=gpt35
DEEPSEEK_MODEL=deepseek-chat
OPENAI_MODEL=gpt-4o-mini
GPT35_MODEL=gpt-3.5-turbo

# Response Configuration
DEFAULT_RESPONSE_TYPE=general
DEFAULT_TEMPERATURE=0.7
MAX_TOKENS=4000
# Production deployment settings
CORS_ORIGINS=https://yourdomain.com
MAX_WORKERS=4
MAX_HISTORY_TURNS=20
